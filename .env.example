# ============================================================
# Variáveis de ambiente para produção — Railway.app
# Copie este arquivo para .env.local em desenvolvimento
# Configure estas variáveis no painel do Railway em produção
# ============================================================

# Banco de dados SQLite (Railway Volume montado em /data)
DATABASE_URL="file:/data/prod.db"

# NextAuth v5 — gere um segredo forte:
#   openssl rand -base64 32
AUTH_SECRET="SUBSTITUA_POR_UM_SEGREDO_FORTE_32_BYTES"

# URL pública do app (defina após obter a URL do Railway)
AUTH_URL="https://SEU_APP.up.railway.app"
NEXTAUTH_URL="https://SEU_APP.up.railway.app"

# Credenciais do admin (criado automaticamente no primeiro start)
ADMIN_EMAIL="admin@novaambiental.com.br"
ADMIN_PASSWORD="SUBSTITUA_POR_SENHA_FORTE"

# Diretório de uploads (opcional — se quiser persistência total)
# Crie um Volume no Railway e monte em /data/uploads
# UPLOAD_DIR="/data/uploads"
