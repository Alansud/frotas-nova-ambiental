# ============================================================
# Variáveis de ambiente — copie para .env.local e preencha
# ============================================================

# Banco de dados PostgreSQL (Render.com / produção)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# NextAuth v5 — gere um segredo forte:
#   openssl rand -base64 32
AUTH_SECRET="SUBSTITUA_POR_UM_SEGREDO_FORTE_32_BYTES"

# URL pública do app (defina após obter a URL do Render)
AUTH_URL="https://SEU_APP.onrender.com"
NEXTAUTH_URL="https://SEU_APP.onrender.com"
AUTH_TRUST_HOST=true

# Credenciais do admin (criado automaticamente no primeiro start)
ADMIN_EMAIL="admin@novaambiental.com.br"
ADMIN_PASSWORD="SUBSTITUA_POR_SENHA_FORTE"
