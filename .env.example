# ============================================================
# Variáveis de ambiente — Nova Ambiental Frotas
# Netlify: configure em Site Settings → Environment Variables
# Local:   copie para .env.local e preencha
# ============================================================

# Banco de dados PostgreSQL
# Opções gratuitas: Neon (neon.tech), Supabase (supabase.com), Render (render.com)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# NextAuth v5 — gere um segredo forte (32+ bytes):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="SUBSTITUA_POR_UM_SEGREDO_FORTE_32_BYTES"

# URL pública do app (use a URL do Netlify após o primeiro deploy)
AUTH_URL="https://SEU_APP.netlify.app"
NEXTAUTH_URL="https://SEU_APP.netlify.app"
AUTH_TRUST_HOST=true

# Credenciais do admin (criado/atualizado automaticamente em cada deploy)
ADMIN_EMAIL="admin@novaambiental.com.br"
ADMIN_PASSWORD="SUBSTITUA_POR_SENHA_FORTE"
